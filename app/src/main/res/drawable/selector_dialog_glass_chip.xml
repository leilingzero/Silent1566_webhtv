<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_enabled="false">
        <shape android:shape="rectangle">
            <corners android:radius="6dp" />
            <solid android:color="#38363A70" />
            <stroke android:width="1dp" android:color="#1F9B9FD0" />
            <padding android:left="14dp" android:top="8dp" android:right="14dp" android:bottom="8dp" />
        </shape>
    </item>
    <item android:drawable="@drawable/shape_dialog_glass_chip_active" android:state_focused="true" android:state_selected="true" />
    <item android:drawable="@drawable/shape_dialog_glass_chip_active" android:state_checked="true" />
    <item android:drawable="@drawable/shape_dialog_glass_chip_active" android:state_activated="true" />
    <item android:drawable="@drawable/shape_dialog_glass_chip_active" android:state_selected="true" />
    <item android:drawable="@drawable/shape_dialog_glass_chip_active" android:state_focused="true" />
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="6dp" />
            <solid android:color="#78383C73" />
            <stroke android:width="1dp" android:color="#3D9B9FD0" />
            <padding android:left="14dp" android:top="8dp" android:right="14dp" android:bottom="8dp" />
        </shape>
    </item>
</selector>
